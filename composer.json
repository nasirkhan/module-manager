{
  "name": "nasirkhan/module-manager",
  "description": "Module Manager & Generator for Laravel Starter Kit (https://github.com/nasirkhan/laravel-starter)",
  "keywords": [
    "laravel starter",
    "nasirkhan",
    "nasirkhansaikat",
    "module manager",
    "module generator"
  ],
  "homepage": "https://github.com/nasirkhan/module-manager",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Nasir Khan",
      "email": "nasir8891@gmail.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.3 || ^8.4",
    "laravel/framework": "^12.0 || ^13.0",
    "opcodesio/log-viewer": "^3.21",
    "sqids/sqids": "^0.5.0",
    "spatie/laravel-backup": "^9.2 || ^10.0",
    "nasirkhan/laravel-jodit": "^1.0.0",
    "yajra/laravel-datatables-oracle": "^12.0 || ^13.0",
  },
  "require-dev": {
    "orchestra/testbench": "^10.0 || ^11.0",
    "phpunit/phpunit": "^11.0 || ^12.0"
  },
  "autoload": {
    "psr-4": {
      "Nasirkhan\\ModuleManager\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Nasirkhan\\ModuleManager\\Tests\\": "tests"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "laravel": {
      "providers": [
        "Nasirkhan\\ModuleManager\\ModuleManagerServiceProvider"
      ],
      "aliases": {
        "ModuleManager": "Nasirkhan\\ModuleManager\\ModuleManagerFacade"
      }
    }
  }
}
